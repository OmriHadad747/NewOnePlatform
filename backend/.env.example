# Copy to .env and fill in. The backend loads .env automatically if
# python-dotenv is installed. Never commit the real .env.

# Pick which provider /extract uses. Defaults to the cheapest in the catalog
# (gemini). Set to "claude" to extract via Claude Haiku.
# AIPM_EXTRACTION_PROVIDER=claude

# Claude (Anthropic) -- required for the claude provider.
ANTHROPIC_API_KEY=
# AIPM_CLAUDE_MODEL=claude-haiku-4-5

# Gemini (Google) -- required for the gemini provider. Either name works.
GEMINI_API_KEY=
# AIPM_GEMINI_MODEL=gemini-2.5-flash

# AIPM_EVENT_LOG=data/events.jsonl
